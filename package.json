{
  "name": "kernel-build-action",
  "version": "1.9.2",
  "description": "Android Kernel Build Action",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --minify --platform=node --target=node24 --outfile=dist/index.js && esbuild src/post.ts --bundle  --minify --platform=node --target=node24 --outfile=dist/post/index.js --format=cjs",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "test": "vitest --coverage",
    "biome": "biome lint src/",
    "biome:fix": "biome lint --write src/"
  },
  "dependencies": {
    "@actions/artifact": "^6.2.1",
    "@actions/cache": "^6.0.0",
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.1.1",
    "@actions/tool-cache": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@eslint/js": "^10.0.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^3.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^3.0.0"
  }
}
