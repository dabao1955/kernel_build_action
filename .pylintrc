[MASTER]
# Python version
py-version = 3.10

# Ignore external/legacy files
ignore = mkdtboimg.py

# Disable some style warnings that don't affect functionality
disable =
    C0301,  # line-too-long
    R0912,  # too-many-branches
    R0914,  # too-many-locals
    R0915,  # too-many-statements
    W0707,  # raise-missing-from
    W0613,  # unused-argument (common in test fixtures)
    R0903,  # too-few-public-methods (common in test classes)
    C0415,  # import-outside-toplevel (common in tests)
    W0621,  # redefined-outer-name (common with pytest fixtures)
    W0718,  # broad-exception-caught
    W0612,  # unused-variable
    E0401   # import-error (for pytest in CI)

[FORMAT]
# Allow longer lines
max-line-length = 120

[DESIGN]
# Allow more complex functions
max-args = 10
max-locals = 20
max-branches = 20
max-statements = 100
